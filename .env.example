# Facebook Graph API credentials
# Used by fetch-reviews.js to pull reviews from your Facebook page
# Do NOT commit the real .env file — it's in .gitignore

# Your Facebook Page numeric ID (find it at facebook.com/your-page/about or via the Graph API)
FACEBOOK_PAGE_ID=your_page_id_here

# Long-lived Page Access Token
# Generate via: https://developers.facebook.com/tools/explorer/
# Required permissions: pages_read_engagement, pages_show_list
FACEBOOK_ACCESS_TOKEN=your_access_token_here
